__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.venv/
venv/
build/
dist/
# Reconciliation artifacts (written by BookReconciliationStore to project-relative paths)
# Includes inspections, proposals, plans, publications, previews, candidates, decisions, accepted-sources, and recompositions.
**/book/expression/reconciliation/

# Dogfood workspaces (regenerated by tests/scripts; must stay outside examples/
# and must never be committed -- see CanonicalStoryBootstrap.copy_to)
/temp/

# Scratch/development directories (agent scratchpads, brainstorm outputs)
.superpowers/

# Example temp/dogfood directories (regenerated from canonical example)
examples/canonical_story/temp_*/

# Windows temp files that sometimes get committed (glob-based, catches absolute paths)
*AppData/Local/Temp/*

# ReasoningRuntime report output (generated test artifacts)
reports/

# Root-level JSON files (test/report artifacts)
/*.json
